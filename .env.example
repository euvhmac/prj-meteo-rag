# ══════════════════════════════════════════════════════════
# MeteoRAG — Environment Variables
# Copie este arquivo para .env e preencha os valores
# ══════════════════════════════════════════════════════════

# ── LLM (Anthropic API direta) ──────────────────────────
METEORAG_ANTHROPIC_API_KEY=         # obrigatório — API key da Anthropic (sk-ant-...)
METEORAG_ANTHROPIC_BASE_URL=        # opcional (deixar vazio para API direta)
METEORAG_LLM_MODEL=claude-haiku-4-5-20251001
METEORAG_LLM_MAX_TOKENS=8192
METEORAG_LLM_TIMEOUT_SECONDS=30

# ── INMET (apenas alertas — best-effort) ─────────────────
METEORAG_INMET_BASE_URL=https://apitempo.inmet.gov.br
METEORAG_INMET_CACHE_TTL_SECONDS=1800
METEORAG_INMET_RETRY_MAX=3
METEORAG_INMET_TIMEOUT_SECONDS=20

# ── Open-Meteo (fonte principal de dados) ────────────────
METEORAG_OPENMETEO_TIMEOUT_SECONDS=20
METEORAG_DEFAULT_DAYS_BACK=7

# ── RAG ──────────────────────────────────────────────────
METEORAG_RAG_TOP_K=8
METEORAG_RAG_MAX_CHUNK_SIZE=512
METEORAG_RAG_MAX_HOURLY_CHUNKS=96

# ── APP ──────────────────────────────────────────────────
METEORAG_APP_PORT=8501
METEORAG_LOG_LEVEL=INFO
METEORAG_ENVIRONMENT=development    # development | production
